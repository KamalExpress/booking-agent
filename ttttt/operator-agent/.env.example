BASE_URL=http://localhost:5000
# Authentication
GVC_USERNAME=your_email@example.com
GVC_PASSWORD=your_password

# Captcha
USE_MOCK_CAPTCHA=True
CAPTCHA_API_KEY=your_captcha_service_key
NOPECHA_API_KEY=your_nopecha_api_key

# OTP DB API
OTP_API_ENDPOINT=http://localhost:5001/get-otp
OTP_API_KEY=your_optional_secret

# Appointment Details
# Adjust these based on the exact payload parameters
APPOINTMENT_DATE_FROM=09/07/2026
APPOINTMENT_TYPE=26
APPOINTMENT_VAC_ID=138

# applicant data (These fields will later be moved to a CSV/config for multi-applicant processing)
APPLICANT_EMAIL=your_email@example.com
APPLICANT_FIRSTNAME=YOUR_FIRST_NAME
APPLICANT_SURNAME=YOUR_SURNAME
APPLICANT_DOB=01/01/1990
APPLICANT_PASSPORT=AB123456
APPLICANT_PASSPORT_EXP=01/01/2030
APPLICANT_GENDER_ID=2
APPLICANT_NATIONALITY_ID=197
APPLICANT_PHONE_PREFIX_ID=197
APPLICANT_PHONE=1234567890
BOOKING_FOR=0
